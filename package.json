{
	"name": "grindr-api-dev-tool",
	"version": "1.0.0",
	"description": "",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"prepare": "wget -q https://opengrind.org/openapi.json -O src/lib/schema/openapi.json",
		"build": "bun prepare && vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "bun run dev:desktop",
		"dev:desktop": "bun prepare && bun --bun tauri dev",
		"dev:web": "bun --bun vite dev",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"preview": "vite preview",
		"tauri": "tauri"
	},
	"dependencies": {
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-opener": "^2",
		"marked": "^18.0.3",
		"svelte-jsoneditor": "^3.12.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.9.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2",
		"@types/node": "^24",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"paneforge": "^1.0.2",
		"phosphor-svelte": "^3.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~5.6.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^6.0.3"
	}
}